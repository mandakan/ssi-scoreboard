# SSI Lab — local environment variables
# Copy to .env.local and fill in your values.
#
# Usage:
#   uv run --env-file .env.local rating db-push
#   uv run --env-file .env.local rating db-pull
#   uv run --env-file .env.local rating sync
#
# Or source once in your shell session:
#   source .env.local && uv run rating db-push

# ------------------------------------------------------------
# SSI Scoreboard sync (required for: rating sync, rating pipeline)
# ------------------------------------------------------------
export CACHE_PURGE_SECRET=your-cache-purge-secret-here

# ------------------------------------------------------------
# S3 / Cloudflare R2 storage (required for: rating db-push, rating db-pull)
# ------------------------------------------------------------
export AWS_ACCESS_KEY_ID=your-access-key-id
export AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Bucket name
export LAB_S3_BUCKET=your-bucket-name

# Cloudflare R2 only — set to your account endpoint.
# Leave unset for standard AWS S3.
export LAB_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Optional: key prefix inside the bucket (default: lab)
# export LAB_S3_PREFIX=lab
