{
  "name": "ssi-scoreboard",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "docker:build": "BUILD_ID=$(git rev-parse --short HEAD 2>/dev/null || echo '') BUILD_DATE=$(date +%Y.%m.%d) docker compose build",
    "docker:up": "docker compose --env-file .env.local up",
    "docker:down": "docker compose down",
    "cf:build": "DEPLOY_TARGET=cloudflare npx @opennextjs/cloudflare@1.17.0 build",
    "cf:deploy": "pnpm cf:build && wrangler deploy",
    "cf:deploy:staging": "pnpm cf:build && wrangler deploy --env staging",
    "setup": "cp -n .env.local.example .env.local || true",
    "icons": "bash scripts/generate-icons.sh"
  },
  "dependencies": {
    "@tanstack/react-query": "5.90.21",
    "@upstash/redis": "1.36.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "ioredis": "5.9.3",
    "lucide-react": "0.575.0",
    "next": "16.1.6",
    "next-themes": "0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.7.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.17.0",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "28.1.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "wrangler": "4.68.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw"
    ],
    "overrides": {
      "minimatch": "^10.2.2"
    }
  }
}
