{
  "name": "ssi-scoreboard",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "social-preview": "node scripts/generate-social-preview.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "docker:build": "BUILD_ID=$(git rev-parse --short HEAD 2>/dev/null || echo '') BUILD_DATE=$(date +%Y.%m.%d) docker compose build",
    "docker:up": "docker compose --env-file .env.local up",
    "docker:down": "docker compose down",
    "cf:build": "DEPLOY_TARGET=cloudflare npx @opennextjs/cloudflare@1.19.4 build",
    "cf:deploy": "pnpm cf:build && wrangler deploy",
    "cf:deploy:staging": "pnpm cf:build && wrangler deploy --env staging",
    "setup": "cp -n .env.local.example .env.local || true",
    "icons": "bash scripts/generate-icons.sh",
    "warm-cache": "tsx scripts/warm-cache.ts",
    "release:post": "tsx scripts/generate-release-post.ts",
    "release:screenshots": "tsx scripts/screenshot-match.ts",
    "check:ssi-schema": "tsx scripts/check-ssi-schema.ts",
    "validate:ssi-queries": "tsx scripts/validate-ssi-queries.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@tanstack/react-query": "5.90.21",
    "@upstash/redis": "1.37.0",
    "better-sqlite3": "12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "geist": "1.7.0",
    "ioredis": "5.10.0",
    "lucide-react": "0.577.0",
    "next": "16.2.4",
    "next-themes": "0.4.6",
    "qrcode.react": "4.2.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "3.8.0",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.19.4",
    "@playwright/test": "1.58.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^22",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "5.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "graphql": "16.13.2",
    "jsdom": "28.1.0",
    "shadcn": "^4.0.6",
    "tailwindcss": "^4.2.1",
    "tsx": "4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "wrangler": "4.85.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "msw",
      "workerd"
    ],
    "overrides": {
      "minimatch": "^10.2.2",
      "hono": "^4.12.15",
      "@hono/node-server": "^1.19.14",
      "express-rate-limit": "^8.2.2",
      "fast-xml-parser": "^5.7.2",
      "undici": "^7.24.1",
      "flatted": "^3.4.2",
      "postcss": "^8.5.12",
      "vite": "^7.3.2",
      "path-to-regexp@>=8.0.0 <9": "^8.4.2",
      "picomatch@>=2.0.0 <3": "^2.3.2",
      "picomatch@>=4.0.0 <5": "^4.0.4",
      "eslint-plugin-react-hooks": "7.0.1"
    }
  }
}
