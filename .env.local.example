# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored and never committed.

# ShootNScoreIt API key — get it from your account settings on shootnscoreit.com
SSI_API_KEY=your_api_key_here

# Secret for the cache purge endpoint — any strong random string
# Used as the Bearer token in: DELETE /api/admin/cache/purge?ct=22&id=<id>
CACHE_PURGE_SECRET=change-me-to-a-strong-random-string

# ── Docker / Node.js deployment (REDIS_URL) ──────────────────────────────────
# Redis connection URL for the ioredis adapter (default deploy target).
# Default: redis://localhost:6379 (matches the docker-compose redis service)
# Production: set to your managed Redis URL, e.g. rediss://... for Upstash
REDIS_URL=redis://localhost:6379

# ── Cloudflare Pages deployment (UPSTASH_REDIS_REST_*) ───────────────────────
# Only needed when building with DEPLOY_TARGET=cloudflare (pnpm cf:build).
# Create a free Redis database at https://upstash.com and copy the REST URL/token.
# These are set as Cloudflare secrets in production (wrangler secret put …).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
