{
  "mcpServers": {
    "shadcn": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["dlx", "shadcn@4", "mcp"]
    },
    "ssi-scoreboard": {
      "type": "stdio",
      "command": "node_modules/.bin/tsx",
      "args": ["mcp/src/index.ts"],
      "env": {
        "SSI_SCOREBOARD_BASE_URL": "https://scoreboard.urdr.dev"
      }
    },
    "ssi-scoreboard-local": {
      "type": "stdio",
      "command": "node_modules/.bin/tsx",
      "args": ["mcp/src/index.ts"],
      "env": {
        "SSI_SCOREBOARD_BASE_URL": "http://localhost:3000"
      }
    }
  }
}
